<?xml version="1.0" encoding="utf-8"?>
<!--
  App icon background: deep purple-to-black radial gradient matching CompassNav theme.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Dark purple background -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="76">
                <item android:offset="0.0" android:color="#2D1B4E" />
                <item android:offset="0.5" android:color="#1A0033" />
                <item android:offset="1.0" android:color="#050009" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle grid lines for depth -->
    <path
        android:fillColor="#00000000"
        android:pathData="M0,54L108,54"
        android:strokeWidth="0.5"
        android:strokeColor="#1AA855F7" />
    <path
        android:fillColor="#00000000"
        android:pathData="M54,0L54,108"
        android:strokeWidth="0.5"
        android:strokeColor="#1AA855F7" />

    <!-- Subtle outer ring -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,54 m-46,0 a46,46 0 1,0 92,0 a46,46 0 1,0 -92,0"
        android:strokeWidth="1"
        android:strokeColor="#22A855F7" />

</vector>
